ARGO_ENV=development
ARGO_DATABASE_URL=sqlite:///./argo.db
ARGO_API_TOKEN=change-me
ARGO_AGENT_TOKEN=change-agent-token
ARGO_INLINE_JOBS=true
ARGO_AUTOMATION_POLL_SECONDS=30

ARGO_HERMES_BASE_URL=http://127.0.0.1:8642/v1
ARGO_HERMES_API_KEY=
ARGO_HERMES_MODEL=nvidia/nemotron-3-ultra-550b-a55b
ARGO_REQUIRE_NEMOCLAW=true
ARGO_HERMES_CRON_ACTIVE=false

ARGO_STRIPE_SECRET_KEY=
ARGO_STRIPE_WEBHOOK_SECRET=
ARGO_STRIPE_SUCCESS_URL=http://localhost:3000/campaigns/{campaign_id}?funding=success
ARGO_STRIPE_CANCEL_URL=http://localhost:3000/campaigns/{campaign_id}?funding=cancelled
ARGO_STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/system
ARGO_STRIPE_CONNECT_RETURN_URL=http://localhost:3000/system

ARGO_GMAIL_SENDER=
ARGO_GMAIL_ACCESS_TOKEN=
ARGO_GMAIL_CLIENT_ID=
ARGO_GMAIL_CLIENT_SECRET=
ARGO_GMAIL_REFRESH_TOKEN=
ARGO_GMAIL_LOOKBACK_DAYS=30

ARGO_NVIDIA_API_KEY=
ARGO_NVIDIA_VISION_BASE_URL=https://integrate.api.nvidia.com/v1
ARGO_NVIDIA_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl

# Optional integrations.
ARGO_YOUTUBE_API_KEY=
ARGO_TELEGRAM_BOT_TOKEN=
ARGO_TELEGRAM_APPROVAL_MODE=full_autonomy
